APP_NAME=Sistem-Sign-Digital
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database Settings ---
# Use 'mysql' for local development (XAMPP/Laragon)
# Use 'pgsql' for Laravel Cloud Production
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# --- Session & Cache ---
# Set to 'file' if you don't have a database connected
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
FILESYSTEM_DISK=cloud_storage
QUEUE_CONNECTION=sync

# --- Laravel Cloud / Object Storage (R2) ---
# Find these in your Laravel Cloud Dashboard > Object Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Others ---
MAIL_MAILER=log
VITE_APP_NAME="${APP_NAME}"
